# JCodeQuest — Docker Compose 환경 변수.
# 이 파일은 .gitignore에 있음 — 커밋 금지.
#
# 사용: docker compose --env-file .env.docker up --build -d

# ─── DB (Supabase PostgreSQL) ───────────────────────────────────────
# Supabase 대시보드 → Project Settings → Database → Connection string (Transaction Pooler 권장).
# 예: postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
JCQ_DB_URL=postgresql://postgres.ialftguxxbggqauvttxc:Qwer5135373@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# ─── backend ↔ judge 공유 webhook 시크릿 ────────────────────────────
JCQ_INTERNAL_SECRET=1234

# ─── 인증 (Supabase Auth) ──────────────────────────────────────────
# Supabase 대시보드 → Project Settings → API → Project URL
SUPABASE_URL=https://ialftguxxbggqauvttxc.supabase.co
# 레거시 HS256 프로젝트만 사용. 신규(ES256/RS256)는 JWKS로 검증하므로 비워두면 됨.
# SUPABASE_JWT_SECRET=

# 개발용 dev-login 활성 (Bearer JWT 없이 쿠키 세션 — 운영에선 제거)
JCQ_AUTH_ALLOW_DEV_STUB=1
# HTTP(로컬) 환경에서 Secure 쿠키 비활성화 — 운영(HTTPS)에선 비워두기
JCQ_COOKIE_INSECURE=1
JCQ_ADMIN_TOKEN=change-me-admin-32B-random

# ─── 튜터 LLM (OpenAI 호환 — factchat 프록시) ────────────────────────
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
OPENAI_MODEL=gpt-5.1

# ─── Ollama (원격 A6000) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://113.198.66.77:10233/

# ─── 채점 / 출제 워커 ───────────────────────────────────────────────
JCQ_QUEUE_CONCURRENCY=1
JCQ_SUBMIT_COOLDOWN_S=10
# DEV ONLY — Ollama 없이 개발할 때 3-LLM 앙상블 스킵. 운영 금지.
# JCQ_SKIP_ENSEMBLE=1

# ─── CORS (외부 호스트에서 접속할 때만) ─────────────────────────────
# 로컬 개발(localhost:5173/5500/8001)은 코드 기본값으로 항상 허용.
# 외부 origin은 쉼표 구분 — scheme/host/port 정확 일치만 통과.
# 예: JCQ_CORS_ORIGINS=https://jcq.example.com,http://203.0.113.10:5173
# JCQ_CORS_ORIGINS=
# IP 대역 전체를 허용하려면 정규식 — 예: ^https?://192\.168\.\d+\.\d+(:\d+)?$
# JCQ_CORS_ORIGIN_REGEX=

