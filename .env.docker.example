# JCodeQuest — Docker Compose 환경 변수 템플릿.
# cp .env.docker.example .env.docker  &&  값 채워서 사용.

# ─── 필수 ───────────────────────────────────────────────
# backend ↔ judge webhook 인증 (32B+ 랜덤). 양 서비스에 같은 값으로 주입됨.
JCQ_INTERNAL_SECRET=change-me-32B-random

# Starlette SessionMiddleware (OAuth 핸드셰이크용 임시 쿠키 서명)
SESSION_SECRET_KEY=change-me-32B-random

# 튜터 LLM
OPENAI_API_KEY=sk-...

# Google OAuth (운영). 개발만 할 거면 JCQ_AUTH_ALLOW_DEV_STUB=1로 우회 가능.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Ollama (3-judge ensemble / 출제 LLM). 호스트의 Ollama를 쓰려면 host.docker.internal 기본값 사용.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── 선택 ───────────────────────────────────────────────
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-5.1

# 로그인 성공 후 리다이렉트 — 프론트가 docker compose의 frontend(:5500)에 떠 있으면 기본값 그대로.
JCQ_FRONTEND_REDIRECT_URL=http://localhost:5500/

# Google Workspace 도메인 게이트. 비우면 모든 도메인 허용 (비권장).
JCQ_AUTH_ALLOWED_HD=jbnu.ac.kr

# 같은 (user, problem) 두 제출 사이 최소 간격(초). 0이면 비활성.
JCQ_SUBMIT_COOLDOWN_S=10

# 채점 워커 동시성 (judge 측).
JCQ_QUEUE_CONCURRENCY=1

# 출제 엔진 파라미터
JCQ_AUTHOR_MODEL=qwen2.5-coder:14b-instruct-q5_K_M
JCQ_VARIANT_COUNT=5
JCQ_AUTHOR_RETRIES=2
JCQ_JUDGE_PASS_THRESHOLD=0.7
JCQ_SOLVER_PASS_MIN_AC=1

# LangSmith — judge / authoring 각각 별도 키·프로젝트 (선택, 키가 있을 때만 활성)
# LANGSMITH_API_KEY_JUDGE=lsv2_pt_...
# LANGSMITH_PROJECT_JUDGE=jcq-judge
# LANGSMITH_API_KEY_AUTHORING=lsv2_pt_...
# LANGSMITH_PROJECT_AUTHORING=jcq-authoring
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# 개발 전용 — POST /auth/dev-login 라우트 등록. prod 절대 금지.
# JCQ_AUTH_ALLOW_DEV_STUB=1
