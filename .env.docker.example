# JCodeQuest — Docker Compose 환경 변수 템플릿.
# cp .env.docker.example .env.docker  &&  값 채워서 사용.

# ─── 필수 ───────────────────────────────────────────────
# DB (Supabase PostgreSQL — Transaction Pooler URL 권장)
# 대시보드 → Project Settings → Database → Connection string
JCQ_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# backend ↔ judge webhook 인증 (32B+ 랜덤). 양 서비스에 같은 값으로 주입됨.
JCQ_INTERNAL_SECRET=change-me-32B-random

# admin_dashboard ↔ authoring 인증 (Bearer 토큰, 32B+ 랜덤).
# 사람이 대시보드 ⚙ 설정 화면에 직접 붙여 넣어 사용 — 컨테이너 안에는 안 들어간다.
# 생성 예: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
JCQ_ADMIN_TOKEN=change-me-admin-32B-random

# Supabase Auth (JWT 검증) — 프로젝트 URL.
# 대시보드 → Project Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# 튜터 LLM
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.1
OPENAI_API_KEY=sk-...

# Ollama (3-judge ensemble / 출제 LLM). 호스트의 Ollama를 쓰려면 host.docker.internal 기본값 사용.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# 프런트엔드 (Vite 빌드 타임에 인라인됨)
# 대시보드 → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
# 브라우저가 backend에 접근할 주소. compose는 host의 8000으로 노출함.
VITE_API_BASE_URL=http://localhost:8000

# admin_dashboard origin — authoring CORS preflight 매칭용. host가 외부 도메인에
# 노출돼 있으면 그 도메인으로 바꿔라 (예: https://admin.example.com). 비워두면 :6010.
# JCQ_DASHBOARD_ORIGIN=http://localhost:6010

# ─── 선택 ───────────────────────────────────────────────
# 레거시 HS256 Supabase 프로젝트만 필요. 신규(ES256/RS256)는 JWKS로 검증되므로 비워둘 것.
# SUPABASE_JWT_SECRET=

# 같은 (user, problem) 두 제출 사이 최소 간격(초). 0이면 비활성.
JCQ_SUBMIT_COOLDOWN_S=10

# 채점 워커 동시성 (judge 측).
JCQ_QUEUE_CONCURRENCY=1

# 출제 엔진 파라미터
JCQ_AUTHOR_MODEL=qwen2.5-coder:14b-instruct-q5_K_M
JCQ_VARIANT_COUNT=5
JCQ_AUTHOR_RETRIES=2
JCQ_JUDGE_PASS_THRESHOLD=0.7
JCQ_SOLVER_PASS_MIN_AC=1

# LangSmith — judge / authoring 각각 별도 키·프로젝트 (선택, 키가 있을 때만 활성)
# LANGSMITH_API_KEY_JUDGE=lsv2_pt_...
# LANGSMITH_PROJECT_JUDGE=jcq-judge
# LANGSMITH_API_KEY_AUTHORING=lsv2_pt_...
# LANGSMITH_PROJECT_AUTHORING=jcq-authoring
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── 개발 전용 (prod 금지) ──────────────────────────────
# POST /auth/dev-login 라우트 등록 (Bearer JWT 없이 쿠키 세션 발급)
# JCQ_AUTH_ALLOW_DEV_STUB=1
# HTTP(로컬) 환경에서 Secure 쿠키 비활성화
# JCQ_COOKIE_INSECURE=1
# Ollama 없이 개발할 때 3-LLM 앙상블 스킵 (샌드박스 테스트는 정상 채점)
# JCQ_SKIP_ENSEMBLE=1
