# JCodeQuest — Docker Compose 환경 변수.
# 이 파일은 .gitignore에 있음 — 커밋 금지.
#
# 사용: docker compose --env-file .env.docker up --build -d

# ─── DB (Supabase PostgreSQL) ───────────────────────────────────────
# Supabase 대시보드 → Project Settings → Database → Connection string (Transaction Pooler 권장).
# 예: postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
JCQ_DB_URL=

# ─── backend ↔ judge 공유 webhook 시크릿 ────────────────────────────
JCQ_INTERNAL_SECRET=change-me-secret-32B-random

# ─── 인증 (Supabase Auth) ──────────────────────────────────────────
# Supabase 대시보드 → Project Settings → API → Project URL
SUPABASE_URL=
# 레거시 HS256 프로젝트만 사용. 신규(ES256/RS256)는 JWKS로 검증하므로 비워두면 됨.
# SUPABASE_JWT_SECRET=

# 개발용 dev-login 활성 (Bearer JWT 없이 쿠키 세션 — 운영에선 제거)
# JCQ_AUTH_ALLOW_DEV_STUB=1
# HTTP(로컬) 환경에서 Secure 쿠키 비활성화 — 운영(HTTPS)에선 비워두기
JCQ_COOKIE_INSECURE=1
JCQ_ADMIN_TOKEN=change-me-admin-32B-random

# ─── 튜터 LLM (OpenAI 호환 — factchat 프록시) ────────────────────────
OPENAI_API_KEY=sk-proj-
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.1

# ─── Ollama (원격 A6000) ────────────────────────────────────────────
OLLAMA_BASE_URL=

# ─── 채점 / 출제 워커 ───────────────────────────────────────────────
JCQ_QUEUE_CONCURRENCY=1
JCQ_SUBMIT_COOLDOWN_S=10
# DEV ONLY — Ollama 없이 개발할 때 3-LLM 앙상블 스킵. 운영 금지.
# JCQ_SKIP_ENSEMBLE=1

# ─── CORS (외부 호스트에서 접속할 때만) ─────────────────────────────
# 로컬 개발(localhost:5173/5500/8001)은 코드 기본값으로 항상 허용.
# 외부 origin은 쉼표 구분 — scheme/host/port 정확 일치만 통과.
# 예: JCQ_CORS_ORIGINS=https://jcq.example.com,http://203.0.113.10:5173
# JCQ_CORS_ORIGINS=
# IP 대역 전체를 허용하려면 정규식 — 예: ^https?://192\.168\.\d+\.\d+(:\d+)?$
# JCQ_CORS_ORIGIN_REGEX=

# ─── 출제 엔진 튜닝 ─────────────────────────────────────────────────
JCQ_AUTHOR_MODEL=qwen3-coder:30b
# 3-LLM 앙상블 (Melchior/Balthasar/Casper) — 출제·채점 두 엔진이 공유하는 판사진.
#  - authoring: solve(후보 풀이) + judge(품질 심사) 공통, compare(원본 비교)는 Melchior 단독
#  - judge_engine: 학생 코드 채점 앙상블 (ensemble.py가 같은 env를 읽음)
JCQ_ENSEMBLE_MODEL_MELCHIOR=qwen2.5-coder:14b-instruct-q5_K_M
JCQ_ENSEMBLE_MODEL_BALTHASAR=deepseek-coder-v2:lite
JCQ_ENSEMBLE_MODEL_CASPER=llama3.1:8b
# 앙상블 context window (solve/judge/compare 공통). generate/verify의 JCQ_AUTHOR_NUM_CTX와 별개.
JCQ_ENSEMBLE_NUM_CTX=8192
# 앙상블 temperature — 채점·심사는 결정론적이어야 하므로 0 권장.
JCQ_ENSEMBLE_TEMPERATURE=0
# generate(draft) temperature — 변형 다양성을 늘리려면 상향.
JCQ_AUTHOR_TEMPERATURE=0
# Ollama keep_alive — 모델을 GPU에 유지하는 시간(모든 LLM 호출 공통). 모델 스왑이 잦으면 짧게.
JCQ_OLLAMA_KEEP_ALIVE=30m
# verify가 요구하는 최소 test_input 개수.
JCQ_AUTHOR_MIN_TEST_CASES=4
# solver가 풀이 LLM에 노출하는 최대 샘플 케이스 수.
JCQ_SOLVER_SAMPLE_LIMIT=2
JCQ_VARIANT_COUNT=5
JCQ_AUTHOR_RETRIES=2
# 복잡한 문제 JSON truncate 방지 (qwen2.5-coder:14b는 32K까지 가능)
JCQ_AUTHOR_NUM_CTX=16384
# verify 재시도 시 temperature — 0은 결정론적 반복 실패를 유발
JCQ_AUTHOR_RETRY_TEMPERATURE=0.4
# reference_code가 time_limit_ms 대비 통과해야 하는 비율 (이전 0.5 → 0.8)
JCQ_AUTHOR_PERF_RATIO=0.8
JCQ_JUDGE_PASS_THRESHOLD=0.7
JCQ_SOLVER_PASS_MIN_AC=1

# ─── 신규성(중복) 검사 ──────────────────────────────────────────────
# generate가 변형 draft를 임베딩해 같은 카테고리 형제와 코사인 비교, 임계 이상이면 재생성.
# 선행: 원격 Ollama에 `ollama pull bge-m3`(또는 택한 모델),
#       Postgres에 `ALTER TABLE problem ADD COLUMN embedding JSONB;`,
#       기존 문제 백필 `python -m authoring.scripts.backfill_embeddings`.
# 끄려면 JCQ_NOVELTY_ENABLED=0 (임베딩 모델 없이도 파이프라인은 동작 — fail-open).
JCQ_NOVELTY_ENABLED=1
JCQ_EMBED_MODEL=bge-m3
# 코사인 임계값 — 높일수록 더 비슷한 것만 거름(덜 엄격), 낮출수록 더 많이 재생성(엄격). 튜닝 대상.
JCQ_NOVELTY_THRESHOLD=0.88
JCQ_NOVELTY_MAX_RETRIES=2

# ─── LangSmith — judge / authoring 각각 별도 키 ────────────────────
LANGSMITH_API_KEY_JUDGE=
LANGSMITH_PROJECT_JUDGE=

LANGSMITH_API_KEY_AUTHORING=
LANGSMITH_PROJECT_AUTHORING=
LANGCHAIN_TRACING_V2=
LANGCHAIN_ENDPOINT=

# ─── frontend (Vite 빌드 타임에 인라인됨) ───────────────────────────
# Supabase 대시보드 → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# 컨테이너 안 ↔ 호스트 브라우저 통신 경로. compose에서 backend는 호스트 8000으로 노출됨.
VITE_API_BASE_URL=http://localhost:8000