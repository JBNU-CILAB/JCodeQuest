{
  "components": {
    "schemas": {
      "CreateOriginalRequest": {
        "description": "원본 문제 1건을 status='approved'로 직접 등록. 출제 엔진 우회 — 운영자/시드 용도.",
        "examples": [
          {
            "category": "basic",
            "expected_approach": "입력을 정수로 변환 후 2를 곱한다",
            "expected_complexity": "O(1)",
            "level": "bronze",
            "memory_limit_mb": 256,
            "one_line_summary": "정수 두 배 출력",
            "points": 100,
            "reference_code": "n = int(input())\nprint(n * 2)\n",
            "statement": "정수 n이 주어지면 n*2를 출력하라.",
            "test_cases": [
              {
                "expected_stdout": "6",
                "is_sample": true,
                "stdin": "3\n"
              },
              {
                "expected_stdout": "",
                "is_sample": false,
                "stdin": "10\n"
              }
            ],
            "time_limit_ms": 2000,
            "title": "두 배 출력"
          }
        ],
        "properties": {
          "category": {
            "default": "basic",
            "title": "Category",
            "type": "string"
          },
          "expected_approach": {
            "default": "",
            "title": "Expected Approach",
            "type": "string"
          },
          "expected_complexity": {
            "default": "",
            "title": "Expected Complexity",
            "type": "string"
          },
          "forbidden_patterns": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Forbidden Patterns",
            "type": "array"
          },
          "key_insight": {
            "default": "",
            "title": "Key Insight",
            "type": "string"
          },
          "level": {
            "default": "bronze",
            "description": "bronze | silver | gold",
            "pattern": "^(bronze|silver|gold)$",
            "title": "Level",
            "type": "string"
          },
          "memory_limit_mb": {
            "default": 256,
            "maximum": 2048.0,
            "minimum": 16.0,
            "title": "Memory Limit Mb",
            "type": "integer"
          },
          "must_handle": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Must Handle",
            "type": "array"
          },
          "one_line_summary": {
            "default": "",
            "title": "One Line Summary",
            "type": "string"
          },
          "points": {
            "default": 100,
            "maximum": 1000.0,
            "minimum": 0.0,
            "title": "Points",
            "type": "integer"
          },
          "reference_code": {
            "description": "autofill에 사용될 정답 Python 소스",
            "examples": [
              "n = int(input())\nprint(n * 2)\n"
            ],
            "title": "Reference Code",
            "type": "string"
          },
          "statement": {
            "description": "문제 본문 (Markdown 허용)",
            "title": "Statement",
            "type": "string"
          },
          "test_cases": {
            "description": "최소 1개. expected_stdout 비면 자동 채움.",
            "items": {
              "$ref": "#/components/schemas/TestCaseInput"
            },
            "minItems": 1,
            "title": "Test Cases",
            "type": "array"
          },
          "time_limit_ms": {
            "default": 2000,
            "maximum": 60000.0,
            "minimum": 100.0,
            "title": "Time Limit Ms",
            "type": "integer"
          },
          "title": {
            "examples": [
              "두 배 출력"
            ],
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "title",
          "statement",
          "reference_code",
          "test_cases"
        ],
        "title": "CreateOriginalRequest",
        "type": "object"
      },
      "CreateOriginalResponse": {
        "properties": {
          "autofill": {
            "description": "자동 채움된 케이스의 메타 (ordinal/elapsed_ms/expected 일부)",
