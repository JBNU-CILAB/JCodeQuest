  "info": {
    "description": "LangGraph 파이프라인으로 원본 문제로부터 변형을 생성하고 같은 SQLite DB에 저장하는 출제 엔진. 백엔드와 동일한 `JCQ_DB_URL`을 공유한다.",
    "title": "JCodeQuest Authoring Engine",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/health": {
      "get": {
        "description": "서버가 떠 있는지 확인하는 단순 핑.",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Api Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "health"
        ]
      }
    },
    "/api/problems": {
      "get": {
        "description": "기본값은 원본(parent_id IS NULL)만. 각 원본에 대해 변형 수와 평균 judge_score를 포함한다.",
        "operationId": "list_problems_api_problems_get",
        "parameters": [
          {
            "description": "false면 변형까지 모두 포함",
            "in": "query",
            "name": "originals_only",
            "required": false,
            "schema": {
              "default": true,
              "description": "false면 변형까지 모두 포함",
              "title": "Originals Only",
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ProblemSummaryOut"
                  },
                  "title": "Response List Problems Api Problems Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "문제 목록 (변형 통계 포함)",
        "tags": [
          "problems"
        ]
      },
      "post": {
        "description": "운영자/시드 용도. `expected_stdout`이 비어 있으면 reference_code를 sandbox에서 실행해 자동으로 채운다. 채움 실패(non-zero/TLE/RE) 시 그 케이스 인덱스를 422에 포함.",
        "operationId": "create_original_api_problems_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOriginalRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateOriginalResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "description": "test_cases 비었거나 level 부정"
          },
          "422": {
            "description": "autofill 실패 — case <i>: <status>"
          }
        },
        "summary": "원본 문제 직접 등록 (출제 엔진 우회)",
        "tags": [
          "problems"
        ]
      }
    },
    "/api/problems/{problem_id}": {
      "get": {
        "description": "reference_code, intent_rubric, authoring_meta, 모든 test_cases를 포함한다. 백엔드의 `/problems/{id}`(학생 시야)와 달리 hidden 정보까지 전부 노출.",
        "operationId": "get_problem_detail_api_problems__problem_id__get",
        "parameters": [
          {
            "description": "문제 ID",
            "in": "path",
            "name": "problem_id",
            "required": true,
            "schema": {
              "description": "문제 ID",
              "title": "Problem Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "문제 없음"
          },
          "422": {
            "content": {
              "application/json": {
