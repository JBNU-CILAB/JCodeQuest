        "title": "GradeAcceptedResponse",
        "type": "object"
      },
      "GradeRequest": {
        "description": "user_id는 인증된 세션에서 추출 — body로 받지 않음(위조 차단).",
        "examples": [
          {
            "code": "n = int(input())\nprint(n * 2)\n",
