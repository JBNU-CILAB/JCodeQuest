{
  "components": {
    "schemas": {
      "AttemptStatusResponse": {
        "description": "제출 화면이 '남은 시도 횟수 / 쿨다운 / AC 여부'를 한 번에 보고 그릴 수 있도록 묶음.",
        "properties": {
          "attempts": {
            "description": "누적 제출 횟수",
            "examples": [
              2
            ],
            "title": "Attempts",
            "type": "integer"
          },
          "can_submit": {
            "description": "현재 시점에 제출 가능 여부 (solved=False & remaining>0 & cooldown<=0)",
            "title": "Can Submit",
            "type": "boolean"
          },
          "cooldown_remaining_s": {
            "description": "다음 제출까지 남은 쿨다운 초. 0 이하면 즉시 가능.",
            "title": "Cooldown Remaining S",
            "type": "number"
          },
          "max_attempts": {
            "description": "문제당 최대 시도 횟수",
            "examples": [
              10
            ],
            "title": "Max Attempts",
            "type": "integer"
          },
          "problem_id": {
            "title": "Problem Id",
            "type": "integer"
          },
          "remaining": {
            "description": "남은 시도 횟수 (max_attempts - attempts)",
            "examples": [
              8
            ],
            "title": "Remaining",
            "type": "integer"
          },
          "solved": {
            "description": "이미 AC를 받은 적이 있는지",
            "title": "Solved",
            "type": "boolean"
          }
        },
        "required": [
          "problem_id",
          "attempts",
          "remaining",
          "max_attempts",
          "solved",
          "cooldown_remaining_s",
          "can_submit"
        ],
        "title": "AttemptStatusResponse",
        "type": "object"
      },
      "EnsembleResult": {
        "properties": {
          "final_verdict": {
            "description": "3명의 심판 투표를 종합한 최종 판정",
            "enum": [
              "AC",
              "SUS"
            ],
            "title": "Final Verdict",
            "type": "string"
          },
          "mode": {
            "description": "unanimous=3/3 동일, majority=2/3 다수결",
            "enum": [
              "unanimous",
              "majority"
            ],
            "title": "Mode",
            "type": "string"
          },
          "votes": {
