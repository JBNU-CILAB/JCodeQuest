# syntax=docker/dockerfile:1.7
# authoring_engineмқҖ backendмқҳ /internal/* HTTP APIмҷҖ judge_engineмқҳ /api/sandbox/runмқ„
# нҶөн•ҙ лҸҷмһ‘н•ңлӢӨ. backend/srcлҘј лҚ” мқҙмғҒ importн•ҳм§Җ м•ҠмңјлҜҖлЎң sharedл§Ң к°ҷмқҙ лҒҢм–ҙмҳЁлӢӨ.
FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

RUN pip install --upgrade "pip>=23.1"

COPY shared/ /app/shared/
COPY authoring_engine/ /app/authoring_engine/

WORKDIR /app/authoring_engine
RUN pip install -e .

EXPOSE 8001

CMD ["uvicorn", "authoring.server:app", "--host", "0.0.0.0", "--port", "8001"]
