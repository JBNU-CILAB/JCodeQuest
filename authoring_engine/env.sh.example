# JCodeQuest Authoring Engine — 환경 변수
# 복사 후 채워서: source env.sh

# 내부 서비스 통신 (필수) — backend·judge_engine과 같은 INTERNAL_SECRET 공유
export JCQ_BACKEND_URL="http://127.0.0.1:8000"
export JCQ_JUDGE_URL="http://127.0.0.1:8002"
export JCQ_INTERNAL_SECRET="change-me"

# Ollama
export OLLAMA_BASE_URL="http://localhost:11434"

# LangSmith 트레이싱 (선택, 권장)
export LANGSMITH_API_KEY="ls__..."
export LANGSMITH_PROJECT="jcq-authoring"
export LANGCHAIN_TRACING_V2="true"
export LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# 출제 엔진 설정 (선택 — 기본값 사용 가능)
export JCQ_AUTHOR_MODEL="qwen2.5-coder:14b-instruct-q5_K_M"
export JCQ_VARIANT_COUNT="5"
export JCQ_AUTHOR_RETRIES="2"
export JCQ_JUDGE_PASS_THRESHOLD="0.7"
export JCQ_SOLVER_PASS_MIN_AC="1"
