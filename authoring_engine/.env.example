# ─── 내부 서비스 통신 (필수) ─────────────────────────────────────────
# DB·sandbox 접근은 모두 backend·judge_engine을 거친다. 같은 시크릿을 공유.
JCQ_BACKEND_URL=http://127.0.0.1:8000
JCQ_JUDGE_URL=http://127.0.0.1:8002
JCQ_INTERNAL_SECRET=change-me

# ─── 관리 대시보드 (admin_dashboard/index.html) ───────────────────────
# /api/health 제외 모든 라우트가 Bearer 토큰을 요구. setup.sh가 자동 생성한다.
# JCQ_DASHBOARD_ORIGIN은 콤마 구분 가능 — dev.sh의 dashboard_port(:6010)와 동기.
JCQ_ADMIN_TOKEN=change-me-admin-token
JCQ_DASHBOARD_ORIGIN=http://localhost:6010

# ─── Ollama (LLM 호스트) ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── LLM 프로바이더 스위치 (빠른 검증용) ───────────────────────────────
# 기본은 ollama(로컬). openai로 바꾸면 generate/verify/judge/solve/attack/compare
# 전 노드가 OpenAI를 쓴다 — 14B 로컬 모델보다 훨씬 빠르게 한 사이클 확인 가능.
# 주의: openai 모드에선 3-judge가 모두 같은 모델(JCQ_OPENAI_MODEL)을 쓴다(다양성↓,
# 중앙값/2-of-3 판정은 유지). 임베딩(novelty·RAG)은 별도로 Ollama를 계속 쓰며,
# Ollama가 없으면 그 게이트들은 fail-open으로 건너뛴다(생성 자체는 진행됨).
# JCQ_LLM_PROVIDER=openai
# JCQ_OPENAI_API_KEY=sk-...            # 없으면 표준 OPENAI_API_KEY로 폴백
# JCQ_OPENAI_MODEL=gpt-4o-mini         # 전 노드 공통 (예: gpt-4o-mini, gpt-4.1-mini)
# JCQ_OPENAI_BASE_URL=                 # OpenAI 호환 엔드포인트(gpt.jbnu.ai 등). 비우면 api.openai.com

# ─── LangSmith 트레이싱 (선택 — 값이 있으면 자동 활성화) ────────────
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=jcq-authoring
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── 출제 엔진 튜닝 (기본값으로 동작 가능) ──────────────────────────
# JCQ_AUTHOR_MODEL=qwen2.5-coder:14b-instruct-q5_K_M
# JCQ_VARIANT_COUNT=5
# JCQ_AUTHOR_RETRIES=2
# JCQ_AUTHOR_NUM_CTX=16384            # 복잡한 문제 JSON truncate 방지 (qwen2.5-coder:14b는 32K까지 가능)
# JCQ_AUTHOR_RETRY_TEMPERATURE=0.4    # verify 재시도 시 다양성 확보 (초안은 항상 0)
# JCQ_AUTHOR_PERF_RATIO=0.8           # reference_code가 time_limit_ms 대비 통과해야 하는 비율 (이전 0.5 → 0.8)
# JCQ_JUDGE_PASS_THRESHOLD=0.7
# JCQ_SOLVER_PASS_MIN_AC=1

# ─── RAG exemplar 검색 (기본 활성 — 설계: docs/rag-authoring-plan.md) ──
# retrieve_exemplars가 같은 카테고리 approved 문제 중 MMR로 "관련 있지만 서로 다른"
# 모범 사례를 골라 draft 프롬프트에 IntentRubric 압축본으로 주입한다.
# 빈 코퍼스(미백필·신규 카테고리)·임베딩 실패는 fail-open(예시 없이 생성).
# JCQ_RAG_ENABLED=1
# JCQ_RAG_TOP_K=3                     # exemplar 개수 (2~4 권장)
# JCQ_RAG_MMR_LAMBDA=0.5             # 관련성 vs 다양성 (>0.7이면 novelty와 충돌 → 0.4~0.5)
# JCQ_RAG_LEVEL_WINDOW=1             # 목표 레벨 ±N 단계(bronze<silver<gold)까지 후보 허용
# JCQ_RAG_MIN_JUDGE_SCORE=0         # judge_score 품질 게이트 (0이면 비활성; None은 항상 통과)
# JCQ_EMBED_MODEL=bge-m3             # 임베딩 모델 (ollama pull 필요, novelty와 공유)
