# ─── 필수 ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# 채점 엔진 HTTP (별도 프로세스 — judge_engine/judge/server.py)
JCQ_JUDGE_URL=http://127.0.0.1:8002

# 채점 엔진 ↔ backend webhook 인증 (judge_engine .env와 같은 값. 32B+ 랜덤)
# scripts/setup.sh 실행 시 비어있으면 자동 생성됨.
JCQ_INTERNAL_SECRET=

# ─── 선택 ─────────────────────────────────────────────────────────
# OPENAI_BASE_URL=https://your-proxy.example.com/v1
# OPENAI_MODEL=gpt-5.1

# 절대경로 권장 (상대경로는 CWD에 따라 다른 DB를 가리킴)
JCQ_DB_URL=sqlite:////absolute/path/to/backend/data/jcq.db

# 채점 워커 동시성은 이제 judge_engine 쪽 JCQ_QUEUE_CONCURRENCY로 이전됨.
# JCQ_SUBMIT_COOLDOWN_S=10

# ─── 테스트 전용 ────────────────────────────────────────────────────
# JCQ_RUN_LIVE_LLM=1
