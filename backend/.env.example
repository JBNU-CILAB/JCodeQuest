# ─── 필수 ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# 채점 엔진 HTTP (별도 프로세스 — judge_engine/judge/server.py)
JCQ_JUDGE_URL=http://127.0.0.1:8002

# 채점 엔진 ↔ backend webhook 인증 (judge_engine .env와 같은 값. 32B+ 랜덤)
# scripts/setup.sh 실행 시 비어있으면 자동 생성됨.
JCQ_INTERNAL_SECRET=

# ─── DB (Supabase PostgreSQL) ──────────────────────────────────────
# Supabase 대시보드 → Project Settings → Database → Connection string
JCQ_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── 인증 (Supabase) ───────────────────────────────────────────────
# Supabase 대시보드 → Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=...

# ─── 선택 ─────────────────────────────────────────────────────────
# OPENAI_BASE_URL=https://your-proxy.example.com/v1
# OPENAI_MODEL=gpt-5.1

# 채점 워커 동시성은 이제 judge_engine 쪽 JCQ_QUEUE_CONCURRENCY로 이전됨.
# JCQ_SUBMIT_COOLDOWN_S=10

# DEV ONLY — 3-LLM 앙상블 단계 스킵 (Ollama 없이 개발할 때).
# 샌드박스 테스트는 동일하게 채점됨. 프로덕션에서는 절대 사용 금지.
# JCQ_SKIP_ENSEMBLE=1

# ─── 개발/테스트 전용 ──────────────────────────────────────────────
# dev-login 엔드포인트 활성화 (Bearer JWT 없이 쿠키 세션 발급 — prod 금지)
# JCQ_AUTH_ALLOW_DEV_STUB=1
# HTTP 환경에서 Secure 쿠키 비활성화 (로컬 개발용)
# JCQ_COOKIE_INSECURE=1

# ─── 테스트 전용 ────────────────────────────────────────────────────
# JCQ_RUN_LIVE_LLM=1
