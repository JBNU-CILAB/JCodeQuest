# JCodeQuest Judge Engine — 환경 변수
# 복사 후 채워서: cp .env.example .env

# Ollama (3-judge ensemble용 — Melchior/Balthasar/Casper)
OLLAMA_BASE_URL=http://localhost:11434

# backend webhook 콜백 주소 — `/internal/grade-events`로 결과를 push
JCQ_BACKEND_URL=http://127.0.0.1:8000

# backend와 공유하는 webhook 인증 시크릿 (32B+ 랜덤). backend의 .env와 같은 값.
# `scripts/setup.sh` 실행 시 비어 있으면 자동 생성됨.
JCQ_INTERNAL_SECRET=1234

# 채점 워커 동시성 (기본 1) — backend에서 옮겨옴
# JCQ_QUEUE_CONCURRENCY=1

# 채점 엔진 자체 설정 (선택 — 기본값 사용 가능)
# JCQ_JUDGE_HOST=127.0.0.1
# JCQ_JUDGE_PORT=8002
