# JCodeQuest Judge Engine — 환경 변수
# 복사 후 채워서: cp .env.example .env

# Ollama (3-judge ensemble용 — Melchior/Balthasar/Casper)
OLLAMA_BASE_URL=http://localhost:11434

# backend webhook 콜백 주소 — `/internal/grade-events`로 결과를 push
JCQ_BACKEND_URL=http://127.0.0.1:8000

# backend와 공유하는 webhook 인증 시크릿 (32B+ 랜덤). backend의 .env와 같은 값.
# `scripts/setup.sh` 실행 시 비어 있으면 자동 생성됨.
JCQ_INTERNAL_SECRET=1234

# ─── 관리 대시보드 (admin_dashboard/index.html) ───────────────────────
# /api/submissions* 는 Bearer admin 토큰을 요구한다. authoring_engine과 같은 값.
# JCQ_DASHBOARD_ORIGIN은 콤마 구분 가능 — dev.sh의 dashboard_port(:6010)와 동기.
JCQ_ADMIN_TOKEN=change-me-admin-token
JCQ_DASHBOARD_ORIGIN=http://localhost:6010

# 채점 워커 동시성 (기본 1) — backend에서 옮겨옴
# JCQ_QUEUE_CONCURRENCY=1

# LangSmith 트레이싱 (선택, 권장) — 키가 있으면 자동 활성. 비우면 비활성.
# 채점 1건당 부모 run, 3개 LLM 호출이 자식 run으로 묶여서 LangSmith UI에서 검색·분석 가능.
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=jcq-judge

# DEV ONLY — 3-LLM 앙상블 단계 스킵 (Ollama 없이 개발할 때).
# 샌드박스 테스트는 동일하게 채점되고, 앙상블은 stub AC로 즉시 반환됨.
# scripts/dev.sh up --no-llm 으로 자동 주입됨. 프로덕션에서는 절대 사용 금지.
# JCQ_SKIP_ENSEMBLE=1

# 채점 엔진 자체 설정 (선택 — 기본값 사용 가능)
# JCQ_JUDGE_HOST=127.0.0.1
# JCQ_JUDGE_PORT=8002
